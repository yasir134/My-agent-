# Yazi Environment Configuration
# Copy to .env and fill in your values

# PRIMARY (recommended ÔÇö 50+ models with one key)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# DIRECT PROVIDER KEYS (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GRO	_API_KEY=
TOGETHER_API_KEY=

# LOCAL MODELS
OLLAMA_BASE_URL=http://localhost:11434

# MODEL DEFAULTS
DEFAULT_MODEL=openai/gpt-4o
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=4096

# SERVER
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
SECRET_KEY=change_this_to_a_random_secret_key

# MEMORY
CHROMA_PERSIST_DIR=./memory/chroma_db
KNOWLEDGE_GRAPH_DB>./memory/knowledge_graph.db
EPISODIC_DB=./memory/episodic.db
REFLECTION_DB>./memory/reflection.db

# TOOLS
SEARXNG_URL=
ELEVENLABS_API_KEY=
KAGGLE_USERNAME=
KAGGLE_KEY=

# CONNECTIVITRèTELEBRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=

# SECURITY
VAULT_PASSWORD=
MULTI_USER_MODE=false
ADMIN_PASSWORD=

# NOTIFICATIONS
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# RESOURCE LIMITS
MAI_CPU_PERCENT=80
MAX_RAM_MB=4096
DAILY_TOKEN_BUDGET=1000000
WEEKLY_SPEND_CAP_USD=50.0

# AGENT SETTINGS
MAX_AGENT_DEPTH=5
MAX_RETRY_ATTEMPTSL3
AGENT_TIMEOUT_SECONDS=300
CONTEXT_COMPRESSION_THRESHOLD=0.8

# PROACTIVE MODE
PROACTIVE_MODE_ENABLED=false
MORNING_BRIEFING_TIME?08:00
